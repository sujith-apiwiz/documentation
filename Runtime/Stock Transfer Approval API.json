{
  "openapi": "3.0.1",
  "info": {
    "title": "Stock Transfer Approval API",
    "description": "This API facilitates the initiation of stock transfer approvals between warehouses. It allows users to submit requests for approval of stock transfers from a source warehouse to a destination warehouse, ensuring efficient inventory management and adherence to stock handling protocols.",
    "termsOfService": "https://www.company.com/terms",
    "contact": {
      "name": "Support Team",
      "url": "https://www.company.com/support",
      "email": "support@company.com"
    },
