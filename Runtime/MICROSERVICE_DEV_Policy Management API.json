      "MICROSERVICE_DEV_createPolicy-CreatePolicyRequest": {
        "title": "Policy Creation Request",
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "The unique identifier for the customer associated with the policy.",
            "example": "INS-10001"
          },
