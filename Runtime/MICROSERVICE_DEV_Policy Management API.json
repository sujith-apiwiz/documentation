          "startDate": {
            "type": "string",
            "description": "The date when the policy becomes effective.",
            "example": "2026-07-16"
          },
          "endDate": {
            "type": "string",
            "description": "The date when the policy expires.",
            "example": "2027-07-16"
          },
          "message": {
            "type": "string",
            "description": "Additional message regarding the policy creation.",
            "example": "Insurance policy created successfully."
          }
