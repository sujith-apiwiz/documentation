        "example": {
          "customerId": "INS-10001",
          "policyType": "HEALTH",
          "coverageAmount": 500000,
          "premiumAmount": 12000,
          "startDate": "2026-07-16",
          "endDate": "2027-07-16",
          "beneficiaryName": "John Smith",
          "paymentMode": "ONLINE"
        }
      },
