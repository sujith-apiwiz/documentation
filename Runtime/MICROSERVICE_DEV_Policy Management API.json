            "format": "int32",
            "example": 12000
          },
          "startDate": {
            "type": "string",
            "description": "The start date of the policy coverage in ISO 8601 format.",
            "example": "2026-07-16"
          },
          "endDate": {
            "type": "string",
            "description": "The end date of the policy coverage in ISO 8601 format.",
            "example": "2027-07-16"
          },
          "beneficiaryName": {
            "type": "string",
            "description": "The name of the beneficiary who will receive the benefits from the policy.",
            "example": "John Smith"
          },
          "paymentMode": {
            "type": "string",
            "description": "The mode of payment for the premium (e.g., monthly, annually).",
            "example": "ONLINE"
          }
        },
