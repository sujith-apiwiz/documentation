        "parameters": [
          {
            "$ref": "#/components/parameters/X-Driver-Id"
          },
          {
            "$ref": "#/components/parameters/Content-Type"
          },
          {
            "$ref": "#/components/parameters/parentspanid"
          },
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/x-mock-response"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfirmPaymentForDurationExtensionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment confirmation successful",
            "headers": {
              "Date": {
                "$ref": "#/components/headers/Date"
              },
              "X-Trace-Id": {
                "$ref": "#/components/headers/X-Trace-Id"
              },
              "Content-Type": {
                "$ref": "#/components/headers/Content-Type"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfirmPaymentForDurationExtensionResponse_200"
