      "put": {
        "tags": [
          "Reservation Extensions"
        ],
        "summary": "Confirm Payment for Duration Extension",
        "description": "This operation allows users to confirm payment for extending the duration of an existing reservation. It requires parameters such as driver ID and authorization headers, along with a request body containing payment details. Upon successful processing, the reservation's duration will be extended and a confirmation response will be returned.",
