            "example": 75
          },
          "createdAt": {
            "type": "string",
            "description": "Timestamp when the subscription was created.",
            "example": "2023-10-23T14:48:00Z"
          },
          "symbols": {
            "type": "array",
            "description": "List of stock symbols included in the subscription.",
