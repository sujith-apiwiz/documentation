  "components": {
    "schemas": {
      "SubscriptionRequest": {
        "type": "object",
        "properties": {
          "subscriptionName": {
            "type": "string",
            "description": "Name of the subscription.",
            "example": "123"
          },
          "category": {
            "type": "integer",
            "description": "Category identifier for the subscription.",
            "example": 123
          },
          "symbols": {
            "type": "array",
            "description": "List of stock symbols to track.",
            "example": [
              "AAPL",
              "MSFT",
              "NVDA"
            ],
            "items": {
              "type": "string",
              "description": "Stock symbols to subscribe to.",
              "example": "AAPL"
            }
          },
          "deliveryChannel": {
            "type": "string",
            "description": "Preferred delivery channel for updates.",
            "example": "EMAIL"
          },
          "frequency": {
            "type": "integer",
            "description": "Frequency of notifications, in minutes.",
            "example": 123
          },
          "language": {
            "type": "string",
            "description": "Preferred language for notifications.",
            "example": "123"
          },
          "region": {
            "type": "string",
            "description": "User's region for relevant updates.",
            "example": "US"
          },
          "priority": {
            "type": "integer",
            "description": "Priority level of the subscription.",
            "example": 123
          },
          "clientReference": {
            "type": "string",
            "description": "Reference identifier from the client.",
            "example": "REF-NEWS-001"
          },
          "portfolioId": {
            "type": "integer",
            "description": "Identifier for the user's portfolio.",
            "example": 123
          },
          "deviceType": {
            "type": "string",
            "description": "Type of device used for notifications.",
            "example": "WEB"
          },
          "notificationEnabled": {
            "type": "boolean",
            "description": "Indicates if notifications are enabled.",
            "example": true
          }
        },
        "example": {
          "subscriptionName": 123,
          "category": 123,
          "symbols": [
            "AAPL",
            "MSFT",
            "NVDA"
          ],
          "deliveryChannel": "EMAIL",
          "frequency": 123,
          "language": 123,
          "region": "US",
          "priority": 123,
          "clientReference": "REF-NEWS-001",
          "portfolioId": 123,
          "deviceType": "WEB",
          "notificationEnabled": true
        }
      },
      "SubscriptionResponse": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "integer",
            "description": "Unique identifier for the subscription.",
            "example": 91
          },
          "subscriptionName": {
            "type": "string",
            "description": "Name assigned to the subscription.",
            "example": "snvcuqiilazijh"
          },
          "category": {
            "type": "integer",
            "description": "Category identifier for the subscription.",
            "example": 96
          },
          "deliveryChannel": {
            "type": "integer",
