            "type": "integer",
            "description": "Subscription category identifier, if provided.",
            "example": 123
          },
          "deliveryChannel": {
            "type": "integer",
            "description": "Identifier for the delivery channel, if applicable.",
            "example": 123
          },
          "frequency": {
            "type": "string",
            "description": "Error message related to the notification frequency.",
            "example": "REAL_TIME"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code of the response.",
            "example": 123
          },
          "createdAt": {
            "type": "string",
            "description": "Timestamp when the error occurred.",
            "example": "2026-06-08T12:00:00Z"
          },
          "symbols": {
            "type": "array",
            "description": "List of stock symbols, if applicable.",
            "example": [
              "AAPL",
              "MSFT",
              "NVDA"
            ],
            "items": {
              "type": "string",
              "example": "SYMBL"
            }
          },
          "notificationEnabled": {
            "type": "boolean",
            "description": "Indicates if notifications are enabled when the error occurred.",
            "example": false
          },
          "message": {
            "type": "string",
            "description": "Detailed error message explaining the issue.",
            "example": "123"
          }
        },
        "example": {
          "subscriptionId": 123,
          "subscriptionName": "Tech News Feed",
          "category": 123,
          "deliveryChannel": 123,
          "frequency": "REAL_TIME",
          "status": 123,
          "createdAt": "2026-06-08T12:00:00Z",
          "symbols": [
            "AAPL",
            "MSFT",
            "NVDA"
          ],
          "notificationEnabled": 123,
          "message": 123
