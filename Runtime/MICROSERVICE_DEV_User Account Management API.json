            "description": "Current status of the account (e.g., active, inactive).",
            "example": "ACTIVE"
          },
          "branchCode": {
            "type": "string",
            "description": "Branch code where the account was created.",
            "example": "BR-2001"
          },
          "createdDate": {
            "type": "string",
            "description": "The date when the account was created.",
            "example": "2026-07-16T09:30:00Z"
          },
          "message": {
            "type": "string",
            "description": "Additional message related to account creation.",
            "example": "Bank account created successfully."
          }
        },
        "description": "This schema represents the response returned upon successful account creation.",
