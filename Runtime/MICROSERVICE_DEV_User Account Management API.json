      "MICROSERVICE_DEV_createAccount-CreateAccountRequest": {
        "title": "Account Creation Request",
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "The unique identifier for the customer.",
            "example": "BANK-20001"
          },
          "accountType": {
            "type": "string",
            "description": "The type of account being created (e.g., savings, checking).",
            "example": "SAVINGS"
          },
          "currency": {
            "type": "string",
            "description": "The currency for the account.",
            "example": "USD"
          },
          "initialDeposit": {
            "type": "integer",
            "description": "The initial deposit amount to open the account.",
            "format": "int32",
            "example": 7500
          },
          "branchCode": {
            "type": "string",
            "description": "The code of the branch where the account will be created.",
            "example": "BR-2001"
          },
          "customerCategory": {
            "type": "string",
            "description": "The category of the customer (e.g., individual, business).",
            "example": "PREMIUM"
          },
          "accountFeatures": {
            "description": "Features associated with the account.",
            "$ref": "#/components/schemas/MICROSERVICE_DEV_createAccount-AccountFeatures"
          }
        },
        "description": "Schema representing the request body for creating a new account.",
        "example": {
          "customerId": "BANK-20001",
          "accountType": "SAVINGS",
          "currency": "USD",
          "initialDeposit": 7500,
          "branchCode": "BR-2001",
          "customerCategory": "PREMIUM",
          "accountFeatures": {
            "onlineBanking": true,
            "mobileBanking": true
          }
        }
      },
      "MICROSERVICE_DEV_createAccount-AccountFeatures": {
        "title": "Account Features",
        "type": "object",
        "properties": {
