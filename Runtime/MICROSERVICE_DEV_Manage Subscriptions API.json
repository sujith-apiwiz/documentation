  "components": {
    "schemas": {
      "MICROSERVICE_DEV_createSubscription-CreateSubscriptionRequest": {
        "title": "Subscription Creation Request",
        "type": "object",
        "properties": {
          "planId": {
            "type": "string",
            "description": "The identifier for the subscription plan.",
            "example": "PLAN-5G-PREMIUM"
          },
          "serviceType": {
            "type": "string",
            "description": "The type of service for the subscription.",
            "example": "MOBILE"
          },
          "phoneNumber": {
            "type": "string",
            "description": "Customer's phone number associated with the subscription.",
            "example": "+4915123456789"
          },
          "activationDate": {
            "type": "string",
            "description": "The date when the subscription should be activated.",
            "example": "2026-07-13"
          },
          "billingAccount": {
            "description": "Details of the billing account associated with the subscription.",
            "$ref": "#/components/schemas/MICROSERVICE_DEV_createSubscription-BillingAccount"
          },
          "customerConsent": {
            "description": "Customer's consent details regarding the subscription.",
            "$ref": "#/components/schemas/MICROSERVICE_DEV_createSubscription-CustomerConsent"
          }
        },
        "description": "Schema representing the request body for creating a new subscription.",
        "example": {
          "planId": "PLAN-5G-PREMIUM",
          "serviceType": "MOBILE",
          "phoneNumber": "+4915123456789",
          "activationDate": "2026-07-13",
          "billingAccount": {
            "accountId": "BA-900123",
            "paymentMethod": "DIRECT_DEBIT"
          },
          "customerConsent": {
            "termsAccepted": true,
            "marketingConsent": false
          }
        }
      },
      "MICROSERVICE_DEV_createSubscription-BillingAccount": {
        "title": "Billing Account",
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "description": "The unique identifier for the billing account.",
            "example": "account-5678"
          },
          "paymentMethod": {
            "type": "string",
            "description": "The payment method used for the billing account.",
            "example": "credit_card"
          }
        },
        "description": "Schema representing the billing account information."
      },
      "MICROSERVICE_DEV_createSubscription-CustomerConsent": {
        "title": "Customer Consent",
        "type": "object",
        "properties": {
          "termsAccepted": {
            "type": "boolean",
            "description": "Indicates whether the customer has accepted the terms.",
            "example": true
          },
          "marketingConsent": {
            "type": "boolean",
            "description": "Indicates whether the customer has consented to marketing communications.",
            "example": false
          }
        },
        "description": "Schema representing the customer's consent information."
      },
      "MICROSERVICE_DEV_createSubscription-CreateSubscriptionResponse_500": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "The timestamp when the error occurred.",
            "example": "2026-07-13T11:54:08Z"
          },
          "status": {
            "type": "boolean",
            "description": "Indicates whether the operation was successful.",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "A message describing the error.",
            "example": "Subscription activated successfully."
          },
          "subscription": {
            "description": "Details of the subscription associated with the error.",
            "$ref": "#/components/schemas/MICROSERVICE_DEV_createSubscription-Subscription"
          },
          "billing": {
            "description": "Billing details associated with the subscription.",
            "$ref": "#/components/schemas/MICROSERVICE_DEV_createSubscription-Billing"
          },
          "traceId": {
            "type": "string",
            "description": "A unique identifier for tracing the request in logs.",
            "example": "799e7283-a8be-47e5-88a3-f1d4b67c44f3"
          }
        },
        "description": "Schema representing the error response for the subscription operations POST request.",
        "example": {
          "timestamp": "2026-07-13T11:54:08Z",
          "status": true,
          "message": "Subscription activated successfully.",
          "subscription": {
            "subscriptionId": "SUB-784512",
            "customerId": "CUST-100234",
            "planId": "PLAN-5G-PREMIUM",
            "serviceType": "MOBILE",
            "status": "ACTIVE",
            "activationDate": "2026-07-13",
            "phoneNumber": "+4915123456789"
          },
          "billing": {
            "billingAccountId": "BA-900123",
            "nextBillingDate": "2026-08-13",
            "currency": "EUR",
            "monthlyCharge": 49.99
          },
          "traceId": "799e7283-a8be-47e5-88a3-f1d4b67c44f3"
        }
      },
      "MICROSERVICE_DEV_createSubscription-Subscription": {
        "type": "object",
        "properties": {
          "subscriptionId": {
            "type": "string",
            "description": "The unique identifier of the subscription.",
            "example": "sub-123"
          },
          "customerId": {
            "type": "string",
            "description": "The unique identifier of the customer associated with the subscription.",
            "example": "cust-456"
          },
          "planId": {
            "type": "string",
            "description": "The unique identifier of the plan associated with the subscription.",
            "example": "plan-789"
          },
          "serviceType": {
            "type": "string",
            "description": "Type of service the subscription is for.",
            "example": "premium"
          },
          "status": {
            "type": "string",
            "description": "Current status of the subscription.",
            "example": "active"
          },
          "activationDate": {
            "type": "string",
            "description": "The date when the subscription was activated.",
            "example": "2023-10-01"
          },
          "phoneNumber": {
            "type": "string",
            "description": "The phone number associated with the subscription.",
            "example": "+1234567890"
          }
        },
        "description": "Schema representing the details of a subscription."
      },
      "MICROSERVICE_DEV_createSubscription-Billing": {
        "type": "object",
        "properties": {
          "billingAccountId": {
            "type": "string",
            "description": "The unique identifier for the billing account.",
            "example": "billing-001"
          },
          "nextBillingDate": {
            "type": "string",
            "description": "The date of the next scheduled billing.",
            "example": "2023-11-01"
          },
          "currency": {
            "type": "string",
            "description": "The currency used for the billing.",
            "example": "USD"
          },
          "monthlyCharge": {
            "type": "number",
            "description": "The monthly charge for the subscription.",
            "example": 9.99
          }
        },
        "description": "Schema representing the billing details for a subscription."
      }
    },
