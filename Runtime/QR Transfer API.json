        ],
        "summary": "Initiate a QR code transfer",
        "description": "This endpoint allows the user to initiate a transfer using a QR code. The user needs to provide the necessary transfer details in the request body. After the transfer is initiated, a response will confirm the successful initiation of the QR transfer along with any required identifiers used in the transaction.",
        "operationId": "initiateQrCodeTransfer",
        "parameters": [
          {
            "$ref": "#/components/parameters/content-type"
          },
          {
            "$ref": "#/components/parameters/x-request-id"
          },
          {
            "$ref": "#/components/parameters/x-mock-response"
          }
        ],
        "responses": {
          "404": {
            "description": "Resource not found for transfer",
            "headers": {
              "x-log-id": {
                "$ref": "#/components/headers/x-log-id"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitiateQrCodeTransferResponse_404"
                }
              }
            }
          },
          "200": {
            "description": "Transfer initiated successfully",
            "headers": {
              "x-log-id": {
                "$ref": "#/components/headers/x-log-id"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitiateQrCodeTransferResponse_200"
                }
              }
            }
          },
