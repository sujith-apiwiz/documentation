            "description": "The name of the person who will receive the benefits of the policy.",
            "example": "John Smith"
          },
          "paymentMode": {
            "type": "string",
            "description": "The mode of payment for the insurance premium, such as monthly or annually.",
            "example": "ONLINE"
          }
        },
