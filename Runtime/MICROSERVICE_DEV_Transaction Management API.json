            "type": "string",
            "description": "Suggested actions the user can take to resolve the issue.",
            "example": "Verify account details and retry the transaction."
          }
        },
        "description": "Schema representing the error response for a failed transaction operation (HTTP 404).",
        "example": {
          "timestamp": "2026-07-13T12:20:39Z",
          "status": false,
          "error": "ACCOUNT_NOT_FOUND",
          "message": "Source account details not found for transaction processing.",
