          "message": {
            "type": "string",
            "description": "Detailed error message providing more context about the failure.",
            "example": "Source account details not found for transaction processing."
          },
          "path": {
            "type": "string",
            "description": "The path of the request that resulted in the error.",
            "example": "/v1/finance/transactions"
