        "title": "Transaction Error Response",
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "The timestamp of when the error occurred.",
            "example": "2026-07-13T12:20:39Z"
          },
          "status": {
            "type": "boolean",
            "description": "Indicates if the operation was successful or not.",
            "example": false
