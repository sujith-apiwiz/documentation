            "example": "TRANSFER"
          },
          "amount": {
            "type": "string",
            "description": "Amount involved in the transaction.",
            "example": "****"
          },
          "currency": {
            "type": "string",
            "description": "Currency code for the transaction amount (e.g., USD, EUR).",
            "example": "USD"
          },
          "status": {
            "type": "string",
            "description": "Current status of the transaction (e.g., completed, pending).",
            "example": "SUCCESS"
          },
          "message": {
            "type": "string",
            "description": "Additional message or information regarding the transaction.",
            "example": "Transaction processed successfully."
          }
        },
        "description": "Response schema for a successful transaction operation.",
        "example": {
          "transactionId": "TXN-100001",
          "customerId": "FIN-10001",
          "accountNumber": "ACC-500001",
          "transactionType": "TRANSFER",
          "amount": "****",
          "currency": "USD",
          "status": "SUCCESS",
          "message": "Transaction processed successfully."
        }
