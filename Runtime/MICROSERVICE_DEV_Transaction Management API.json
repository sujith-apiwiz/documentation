            "errorCode": "PAYMENT_GATEWAY_TIMEOUT",
            "message": "Payment gateway timeout while processing transaction request.",
            "gateway": "PAYMENT_PROVIDER",
            "retryable": true
          },
          "suggestion": "Please retry after some time or contact support if the issue persists."
        }
      },
      "MICROSERVICE_DEV_createTransaction-ErrorDetails": {
        "title": "Error Details",
        "type": "object",
        "properties": {
          "accountNumber": {
            "type": "integer",
            "description": "The account number associated with the error.",
            "format": "int32",
            "example": 123456
          },
          "accountType": {
            "type": "string",
            "description": "The type of account that had the issue.",
            "example": "Savings"
          },
          "errorCode": {
            "type": "string",
            "description": "A code representing the specific error.",
            "example": "404_NOT_FOUND"
          },
          "message": {
            "type": "string",
            "description": "A message explaining the error in detail.",
            "example": "Account not found."
          }
        },
        "description": "Detailed information about the error that occurred."
      },
      "MICROSERVICE_DEV_createTransaction-CreateTransactionResponse_200": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string",
            "description": "Unique identifier for the transaction.",
            "example": "TXN-100001"
          },
          "customerId": {
            "type": "string",
            "description": "Unique identifier for the customer who initiated the transaction.",
            "example": "FIN-10001"
          },
          "accountNumber": {
            "type": "string",
            "description": "Account number associated with the transaction.",
            "example": "ACC-500001"
          },
          "transactionType": {
            "type": "string",
            "description": "Type of the transaction (e.g., credit, debit).",
            "example": "TRANSFER"
          },
          "amount": {
            "type": "string",
            "description": "Amount involved in the transaction.",
            "example": "*******"
          },
          "currency": {
            "type": "string",
            "description": "Currency in which the transaction amount is denominated.",
            "example": "USD"
          },
          "status": {
            "type": "string",
            "description": "Current status of the transaction (e.g., pending, completed, failed).",
            "example": "SUCCESS"
          },
          "processedAt": {
            "type": "string",
            "description": "Timestamp indicating when the transaction was processed.",
            "example": "2026-07-15T10:30:00Z"
          },
          "paymentMode": {
            "type": "string",
            "description": "Mode of payment used for the transaction (e.g., credit card, bank transfer).",
            "example": "ONLINE"
          },
          "message": {
            "type": "string",
            "description": "Additional message or notes related to the transaction.",
            "example": "Transaction processed successfully."
          }
        },
        "description": "Response schema for successful transaction creation. This schema provides details of the completed transaction.",
        "example": {
          "transactionId": "TXN-100001",
          "customerId": "FIN-10001",
          "accountNumber": "ACC-500001",
          "transactionType": "TRANSFER",
          "amount": "*******",
          "currency": "USD",
          "status": "SUCCESS",
          "processedAt": "2026-07-15T10:30:00Z",
          "paymentMode": "ONLINE",
          "message": "Transaction processed successfully."
        }
      },
      "MICROSERVICE_DEV_createTransaction-CreateTransactionRequest": {
        "title": "Transaction Request",
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "The unique identifier for the customer.",
            "example": "FIN-99999"
          },
          "accountNumber": {
            "type": "integer",
            "description": "The account number associated with the transaction.",
            "format": "int32",
            "example": 999999
          },
          "transactionType": {
            "type": "string",
            "description": "The type of the transaction (e.g., transfer, deposit, withdrawal).",
            "example": "TRANSFER"
          },
          "amount": {
            "type": "string",
            "description": "The amount of money involved in the transaction.",
            "example": "****"
          },
          "currency": {
            "type": "string",
            "description": "The currency in which the transaction amount is specified (e.g., USD, EUR).",
            "example": "USD"
          },
          "beneficiaryAccount": {
            "type": "string",
            "description": "The account number of the beneficiary in case of transfers.",
            "example": "ACC-800001"
          },
          "transactionDate": {
            "type": "string",
            "description": "The date when the transaction is to be processed.",
            "example": "2026-07-15"
          },
          "paymentMode": {
            "type": "string",
            "description": "The mode of payment for the transaction (e.g., online, cash, check).",
            "example": "ONLINE"
          },
          "remarks": {
            "type": "string",
            "description": "Additional remarks or notes regarding the transaction.",
            "example": "Account settlement"
          }
        },
        "description": "Schema representing a request body for creating a new transaction.",
        "example": {
          "customerId": "FIN-99999",
          "accountNumber": 999999,
          "transactionType": "TRANSFER",
          "amount": "****",
          "currency": "USD",
          "beneficiaryAccount": "ACC-800001",
          "transactionDate": "2026-07-15",
          "paymentMode": "ONLINE",
          "remarks": "Account settlement"
        }
      },
      "MICROSERVICE_DEV_createTransaction-CreateTransactionResponse_404": {
        "title": "Error Response for Transaction Operations",
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "The timestamp when the error occurred.",
            "example": "2026-07-13T12:20:39Z"
          },
          "status": {
            "type": "boolean",
