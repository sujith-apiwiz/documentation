        "description": "Schema representing the request body for creating a transaction operation.",
        "example": {
          "customerId": "FIN-99999",
          "accountNumber": 999999,
          "transactionType": "TRANSFER",
          "amount": "****",
          "currency": "USD",
          "beneficiaryAccount": "ACC-800001",
          "transactionDate": "2026-07-15",
          "paymentMode": "ONLINE",
          "remarks": "Account settlement"
