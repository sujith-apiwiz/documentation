      "MICROSERVICE_DEV_createTransaction-CreateTransactionRequest": {
        "title": "Transaction Request",
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "Unique identifier of the customer initiating the transaction.",
            "example": "FIN-50001"
          },
          "accountNumber": {
            "type": "string",
            "description": "The account number from which the funds will be debited.",
            "example": "ACC-700001"
          },
          "transactionType": {
            "type": "string",
            "description": "The type of transaction (e.g., transfer, withdrawal, deposit).",
            "example": "TRANSFER"
          },
          "amount": {
            "type": "string",
            "description": "The amount of money involved in the transaction.",
            "example": "*****"
          },
          "currency": {
            "type": "string",
            "description": "The currency in which the transaction amount is denominated (e.g., USD, EUR).",
            "example": "USD"
          },
          "beneficiaryAccount": {
            "type": "string",
            "description": "The account number of the beneficiary receiving the funds.",
            "example": "ACC-600001"
          },
          "transactionDate": {
            "type": "string",
            "description": "The date when the transaction is requested to be executed.",
            "example": "2026-07-15"
          }
        },
        "description": "Schema representing the request body for a transaction operation.",
        "example": {
          "customerId": "FIN-50001",
          "accountNumber": "ACC-700001",
          "transactionType": "TRANSFER",
          "amount": "*****",
          "currency": "USD",
          "beneficiaryAccount": "ACC-600001",
          "transactionDate": "2026-07-15"
        }
      },
