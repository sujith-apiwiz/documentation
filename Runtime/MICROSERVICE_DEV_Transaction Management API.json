          "message": {
            "type": "string",
            "description": "Detailed message about the error.",
            "example": "Source account details not found for transaction processing."
          },
          "path": {
            "type": "string",
            "description": "The path of the endpoint that caused the error.",
            "example": "/v1/finance/transactions"
          },
          "trace": {
            "type": "string",
            "description": "A trace of the error for debugging purposes.",
            "example": "f06f97ee-6992-42d3-96e1-7bdce23fdda7"
          },
          "details": {
            "$ref": "#/components/schemas/MICROSERVICE_DEV_createTransaction-ErrorDetails"
          },
          "suggestion": {
            "type": "string",
            "description": "Suggestions for resolving the error.",
            "example": "Verify account details and retry the transaction."
          }
        },
        "description": "This schema represents the error response returned when a transaction operation fails with a 404 status code.",
        "example": {
          "timestamp": "2026-07-13T12:20:39Z",
          "status": false,
          "error": "ACCOUNT_NOT_FOUND",
          "message": "Source account details not found for transaction processing.",
