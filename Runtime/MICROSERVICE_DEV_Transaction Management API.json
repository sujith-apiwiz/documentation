            "type": "string",
            "description": "The payment method used for the transaction, such as 'credit_card' or 'bank_transfer'.",
            "example": "ONLINE"
          },
          "message": {
            "type": "string",
            "description": "A message related to the transaction, typically for status or error information.",
            "example": "Transaction processed successfully."
