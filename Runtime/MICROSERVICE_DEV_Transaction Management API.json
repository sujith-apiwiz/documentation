          "details": {
            "accountNumber": 999999,
            "accountType": "SAVINGS",
            "errorCode": "FIN_ACCOUNT_MISSING",
            "message": "No active account exists for the provided account number."
          },
          "suggestion": "Verify account details and retry the transaction."
        }
      }
