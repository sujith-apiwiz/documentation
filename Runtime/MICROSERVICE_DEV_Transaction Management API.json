            "example": "2026-07-15"
          },
          "paymentMode": {
            "type": "string",
            "description": "The mode of payment (e.g., 'online', 'offline').",
            "example": "ONLINE"
          },
          "remarks": {
            "type": "string",
            "description": "Additional remarks or notes about the transaction.",
            "example": "Account settlement"
          }
